# ═══════════════════════════════════════════════════════════════════
# AgroNet Africa Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env for local development:
#   cp .env.example .env
# For production, paste these Key/Value pairs into your Render Dashboard.
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string (required).
# Local format:  postgresql://USER:PASSWORD@localhost:5432/agronet_db
# Render format: provided automatically when you attach a Render PostgreSQL DB
DATABASE_URL=postgresql://postgres:password@localhost:5432/agronet_db

# Optional pool tuning (defaults shown — override only if needed)
# DB_POOL_MAX=20
# DB_POOL_MIN=2
# DB_IDLE_TIMEOUT=30000
# DB_CONN_TIMEOUT=5000

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Vercel domain here (no trailing slash):
ALLOWED_ORIGINS=http://localhost:3000,https://your-agronet-app.vercel.app
