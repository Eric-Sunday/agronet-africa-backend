# ─────────────────────────────────────────────
# AgroNet Africa Backend — .gitignore
# ─────────────────────────────────────────────

# ── Node.js ──────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn-integrity
package-lock.json.bak

# ── Environment & Secrets ─────────────────────
.env
.env.local
.env.development
.env.staging
.env.production
.env.*.local
*.pem
*.key
*.cert

# ── Logs ──────────────────────────────────────
logs/
*.log

# ── Runtime / Process ─────────────────────────
pids/
*.pid
*.seed
*.pid.lock

# ── Build Output ──────────────────────────────
dist/
build/
out/

# ── OS Cache Files ────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ── Editor & IDE ──────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ── Coverage & Testing ────────────────────────
coverage/
.nyc_output/

# ── Miscellaneous ─────────────────────────────
.cache/
.temp/
tmp/
